# Database Configuration
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=swarparikshan
POSTGRES_USER=swarparikshan
POSTGRES_PASSWORD=swarparikshan_secure_password_CHANGE_ME

# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# MinIO Object Storage
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123_CHANGE_ME

# JWT Configuration
JWT_PRIVATE_KEY=classpath:secrets/private_key.pem
JWT_PUBLIC_KEY=classpath:secrets/public_key.pem

# Google OAuth 2.0
# Get credentials from: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Twilio SMS (for OTP)
# Sign up at: https://www.twilio.com/
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# SendGrid Email
# Sign up at: https://sendgrid.com/
SENDGRID_API_KEY=your_sendgrid_api_key
SENDGRID_FROM_EMAIL=noreply@mayabhedak.com
SENDGRID_FROM_NAME=MayaBhedak

# Razorpay Payment Gateway (India)
# Sign up at: https://dashboard.razorpay.com/
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Stripe Payment Gateway (Alternative)
# Sign up at: https://dashboard.stripe.com/
STRIPE_SECRET_KEY=your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# Service URLs (Internal)
NOTIFICATION_SERVICE_URL=http://notification-service:8085
TRIAL_SERVICE_URL=http://trial-service:8083
AUTH_SERVICE_URL=http://auth-service:8082
GATEWAY_URL=http://gateway:8080

# Frontend URL
FRONTEND_URL=http://localhost:3000

# CORS Allowed Origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# Environment
ENVIRONMENT=development
LOG_LEVEL=DEBUG
